generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Corresponsal {
  id                String   @id @default(uuid())
  nombre            String
  email             String?  @unique
  pais              String?
  taxId             String?
  direccionOficina  String?
  sitioWeb          String?
  calificacion      Int?     @default(3)
  notasInternas     String?
  ciudadesCobertura String[]
  especialidades    String[]
  contactos         Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  casos             Caso[]

  @@map("corresponsales")
}

model Caso {
  id                 Int           @id @default(autoincrement())
  corresponsalId     String
  idCasoAssistravel  String        @unique
  idCasoCorresponsal String?
  fechaInicio        DateTime?
  pais               String?
  tipoServicio       String?
  costoFee           Float?        @default(0)
  costoUsd           Float?        @default(0)
  montoAgregado      Float?        @default(0)
  costoMonedaLocal   Float?        @default(0)
  tasaCambio         Float?        @default(1)
  simboloMonedaLocal String?
  informeMedico      Boolean       @default(false)
  tieneFactura       Boolean       @default(false)
  nroFactura         String?
  fechaEmiFact       DateTime?
  fechaVtoFact       DateTime?
  fechaPagFact       DateTime?
  estadoInterno      EstadoInterno @default(Abierto)
  estadoCaso         EstadoCaso    @default(NoFee)
  observaciones      String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  logs               CasoLog[]
  corresponsal       Corresponsal  @relation(fields: [corresponsalId], references: [id])

  @@map("casos")
}

model CasoLog {
  id            Int      @id @default(autoincrement())
  casoId        Int
  tipo          String
  valorAnterior String?
  valorNuevo    String?
  usuario       String?  @default("Sistema")
  createdAt     DateTime @default(now())
  caso          Caso     @relation(fields: [casoId], references: [id], onDelete: Cascade)

  @@map("caso_logs")
}

model Profile {
  id             String     @id @db.Uuid
  nombreCompleto String
  email          String     @unique
  rol            UserRole   @default(visor)
  estado         UserStatus @default(activo)
  ultimoAcceso   DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@map("profiles")
}

enum UserRole {
  admin
  operador
  visor
}

enum UserStatus {
  activo
  inactivo
}

enum EstadoInterno {
  Abierto
  Cerrado
  Pausado
  Cancelado
}

enum EstadoCaso {
  NoFee
  OnGoing
  Refacturado
  ParaRefacturar
  Cobrado
}

model Report {
  id        String   @id @default(uuid())
  tipo      String   // economico, operativo, financiero, contable
  titulo    String
  contenido String   @db.Text
  dataSnapshot Json? // Backup of the data used for the report
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reports")
}

model Notification {
  id        String   @id @default(uuid())
  tipo      String   // info, warning, error, success
  titulo    String
  mensaje   String
  leida     Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@map("notifications")
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  type      String   @default("string") // string, number, boolean, json
  group     String   @default("general") // general, financial, integration
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}
